# Copia este archivo como .env y completa credenciales reales.

# Base de datos real PostgreSQL / Neon.
DATABASE_URL=postgresql://usuario:password@host/nombre_bd?sslmode=require

# API real de pago. Usa el endpoint sandbox/productivo de tu proveedor.
PAYMENT_API_URL=https://api.proveedor-pagos.com/v1/payments
PAYMENT_API_KEY=coloca_tu_api_key_real
PAYMENT_CURRENCY=PEN
PAYMENT_TIMEOUT_SECONDS=20

# Correo real para confirmaciones.
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=usuario_smtp
SMTP_PASSWORD=password_smtp
SMTP_FROM=reservas@hotelcostaazul.pe
SMTP_USE_TLS=true

# API real de validacion DNI.
APIS_NET_PE_TOKEN=token_real_de_apis_net_pe
APIS_NET_PE_RENIEC_URL=https://api.apis.net.pe/v2/reniec/dni
